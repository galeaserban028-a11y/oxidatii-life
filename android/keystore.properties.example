# Copy to `android/keystore.properties` and fill in your values.
# NEVER commit the real file (it's git-ignored).
# Alternatively, set these as environment variables:
#   OXIDATII_KEYSTORE_PATH, OXIDATII_KEYSTORE_PASSWORD,
#   OXIDATII_KEY_ALIAS, OXIDATII_KEY_PASSWORD
storeFile=/absolute/path/to/oxidatii-release.jks
storePassword=your-keystore-password
keyAlias=oxidatii
keyPassword=your-key-password
