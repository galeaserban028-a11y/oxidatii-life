# ============================================================
# OXIDAȚII — Config pentru publicare pe App Store
# ============================================================
# Copiază acest fișier în ios/fastlane.env și completează valorile.
# NU committa ios/fastlane.env (e deja în .gitignore).
# ============================================================

# Team ID (10 caractere) — îl găsești pe:
# https://developer.apple.com/account → Membership → Team ID
APPLE_TEAM_ID=XXXXXXXXXX

# Bundle ID (deja setat, nu schimba dacă nu ești sigur)
APP_BUNDLE_ID=com.oxidatii.app

# App Store Connect API Key — o creezi o singură dată aici:
# https://appstoreconnect.apple.com/access/integrations/api
# → "+" → Access: "Admin" → Generate (Admin ca să poată crea app-ul automat)
APP_STORE_KEY_ID=XXXXXXXXXX
APP_STORE_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Path către AuthKey_XXXXXXXXXX.p8 descărcat de pe App Store Connect.
# Default: ios/private_keys/AuthKey_${APP_STORE_KEY_ID}.p8
# APP_STORE_KEY_PATH=ios/private_keys/AuthKey_XXXXXXXXXX.p8

# Metadata pentru crearea automată a app-ului (folosite doar prima dată).
# APP_NAME=OXIDAȚII
# APP_SKU=oxidatii-ios
# APP_PRIMARY_LANGUAGE=en-US
