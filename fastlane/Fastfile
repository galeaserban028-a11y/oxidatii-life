# Fastlane config for OXIDAȚII
# Lanes:
#   fastlane beta      → upload IPA la TestFlight (folosit intern de script)
#   fastlane metadata  → push metadata + screenshots (fără binar)
#   fastlane release   → submit for review

default_platform(:ios)

API_KEY_PATH = ENV["FASTLANE_API_KEY_PATH"] || File.expand_path("../../ios/build/asc_api_key.json", __FILE__)

platform :ios do
  desc "Upload existing IPA to TestFlight"
  lane :beta do
    ipa_path = ENV["IPA_PATH"] or UI.user_error!("IPA_PATH env var required")
    pilot(
      api_key_path: API_KEY_PATH,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      skip_submission: true
    )
  end

  desc "Upload App Store metadata + screenshots (no binary)"
  lane :metadata do
    deliver(
      api_key_path: API_KEY_PATH,
      skip_binary_upload: true,
      skip_screenshots: false,
      skip_metadata: false,
      force: true,
      overwrite_screenshots: true,
      run_precheck_before_submit: false,
      submit_for_review: false,
      automatic_release: false
    )
  end

  desc "Submit current version for App Store review"
  lane :release do
    deliver(
      api_key_path: API_KEY_PATH,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: true,
      force: true,
      submit_for_review: true,
      automatic_release: true,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false,
        export_compliance_encryption_updated: false
      }
    )
  end
end
